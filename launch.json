{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Dash App",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/src/world_app_3.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "FLASK_ENV": "development",
                "DASH_DEBUG": "true"
            },
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "python": "${command:python.interpreterPath}"
        },
        {
            "name": "Debug Dash App (No Reload)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/src/world_app_3.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "FLASK_ENV": "development",
                "DASH_DEBUG": "true",
                "WERKZEUG_RUN_MAIN": "true"
            },
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "python": "${command:python.interpreterPath}"
        }
    ]
}